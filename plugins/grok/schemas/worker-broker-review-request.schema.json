{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xliberty2008x/grok-plugin/schemas/worker-broker-review-request.schema.json",
  "title": "Worker Broker Phase 1 Review Request",
  "description": "Immutable, non-authoritative request for an external signed Phase 1 review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "domain",
    "producerId",
    "producerVersion",
    "manifestDigest",
    "phase",
    "createdAt",
    "expiresAt",
    "nonce",
    "source",
    "diff",
    "proof",
    "prerequisite",
    "requestDigest"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "domain": {
      "type": "string",
      "const": "grok-plugin/worker-broker/phase-1-review-request/v1"
    },
    "producerId": {
      "type": "string",
      "const": "worker-broker-review-request-runner"
    },
    "producerVersion": { "type": "integer", "const": 1 },
    "manifestDigest": {
      "type": "string",
      "const": "16adb6811c1e0d16c3b8919a7cc31c9ab6f725df062ae6fadfcc0c7d62529c65"
    },
    "phase": { "type": "string", "const": "1" },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nonce": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{43}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headCommit",
        "headTree",
        "sourceInventoryDigest",
        "phaseScopeDigest",
        "phaseScopePaths"
      ],
      "properties": {
        "headCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "headTree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "sourceInventoryDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "phaseScopeDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "phaseScopePaths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
        }
      }
    },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseCommit",
        "headCommit",
        "patchDigest",
        "pathsDigest",
        "paths"
      ],
      "properties": {
        "baseCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "headCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "patchDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "pathsDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "recordDigest", "producerManifestDigest", "gateIds"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^tests/e2e-results/worker-broker/phase-1/[0-9a-f]{16}-[0-9a-f]{12}\\.json$"
        },
        "recordDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "producerManifestDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "gateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "path", "recordDigest", "gateIds"],
      "properties": {
        "phase": { "type": "string", "const": "0" },
        "path": {
          "type": "string",
          "pattern": "^tests/e2e-results/worker-broker/phase-0/[0-9a-f]{16}-[0-9a-f]{12}\\.json$"
        },
        "recordDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "gateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requestDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
