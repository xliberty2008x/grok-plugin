{
  "name": "grok-plugin",
  "version": "0.3.0-dev.1",
  "private": true,
  "type": "module",
  "description": "Claude Code and Codex companion plugin for the official Grok Build CLI",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:deterministic": "node scripts/test-deterministic.mjs",
    "test:e2e": "node --test tests/live-grok.test.mjs",
    "test:pty-ingress": "node --test tests/pty-ingress.test.mjs",
    "test:installed-codex": "node --test tests/installed-codex.test.mjs",
    "test:natural-codex": "node scripts/test-natural-codex.mjs",
    "codex:update-local": "node scripts/update-local-codex.mjs",
    "validate": "node scripts/validate.mjs",
    "version:check": "node scripts/validate.mjs --versions-only",
    "version:bump": "node scripts/bump-version.mjs",
    "check": "npm run validate && npm run test:deterministic",
    "worker:evidence": "node scripts/worker-broker-evidence.mjs",
    "worker:prove": "node scripts/worker-broker-evidence.mjs prove",
    "worker:verify": "node scripts/worker-broker-evidence.mjs verify",
    "worker:qualify": "node scripts/worker-broker-evidence.mjs qualify"
  },
  "license": "Apache-2.0"
}
