{
  "name": "grok-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Claude Code companion plugin for the official Grok Build CLI",
  "engines": { "node": ">=18.18" },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "node --test tests/live-grok.test.mjs",
    "validate": "node scripts/validate.mjs",
    "version:check": "node scripts/validate.mjs --versions-only",
    "version:bump": "node scripts/bump-version.mjs",
    "check": "npm run validate && npm test"
  },
  "license": "Apache-2.0"
}
